# Godot 4 .gitignore

# Godot-specific ignores
.godot/
*.translation

# Imported resources (regenerated by Godot on open)
.import/

# OS-generated files
.DS_Store
Thumbs.db

# IDE files
*.swp
*.swo
*~
.vscode/
.idea/

# Export builds
export/
build/
*.apk
*.ipa
*.aab

# Mono/C# (not using, but just in case)
.mono/
data_*/
mono_crash.*.json
